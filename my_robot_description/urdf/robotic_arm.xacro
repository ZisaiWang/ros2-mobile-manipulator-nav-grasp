<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

    <xacro:macro name="arm_link" params="prefix">
        <link name="arm_${prefix}_link">
            <visual>
                <origin xyz="0 0 0.1" rpy="0 0 0" />
                <geometry>
                    <cylinder radius="0.02" length="0.2" />
                </geometry>
                <material name="grey" />
            </visual>

            <collision>
                <origin xyz="0 0 0.1" rpy="0 0 0" />
                <geometry>
                    <cylinder radius="0.015" length="0.08" />
                </geometry>
            </collision>

            <xacro:cylinder_inertia 
                m="2.0" 
                r="0.02" 
                h="0.1"
                o_xyz="0 0 0" 
                o_rpy="0 0 0" />
        </link>
    </xacro:macro>

    <xacro:arm_link prefix="1" />
    <xacro:arm_link prefix="2" />

    <link name="arm_base">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <cylinder radius="0.2" length="0.02" /> 
            </geometry>
            <material name="grey" />
        </visual>

        <collision>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <cylinder radius="0.2" length="0.02" />
            </geometry>
        </collision>

        <xacro:cylinder_inertia 
            m="2.0" 
            r="0.2" 
            h="0.02" 
            o_xyz="0 0 0" 
            o_rpy="0 0 0" />
    </link>

    <!-- gripper -->
    <link name="gripper_base">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <box size="0.08 0.03 0.03" />
            </geometry>
            <material name="grey" />
        </visual>

        <!-- <collision>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <box size="0.08 0.03 0.03" />
            </geometry>
        </collision> -->
    </link>

    <joint name="arm2_gripper_base_joint" type="fixed">
        <parent link="arm_2_link" />
        <child link="gripper_base" />
        <origin xyz="0 0 0.2" rpy="0 0 0" />
    </joint>

    <link name="left_finger">
        <visual>
            <origin xyz="0 0 0.04" rpy="0 0 0" />
            <geometry>
                <box size="0.015 0.015 0.08" />
            </geometry>
            <material name="grey" />
        </visual>

        <collision>
            <origin xyz="0 0 0.04" rpy="0 0 0" />
            <geometry>
                <box size="0.015 0.015 0.08" />
            </geometry>
          <surface>
            <friction>
              <ode>
                <mu>2.0</mu>
                <mu2>2.0</mu2>
              </ode>
            </friction>
          </surface>
        </collision>

        <inertial>
            <origin xyz="0 0 0.04" rpy="0 0 0" />
            <mass value="0.05" />
            <inertia 
                ixx="0.00003" ixy="0.0" ixz="0.0"
                iyy="0.00003" iyz="0.0"
                izz="0.00001" />
        </inertial>
    </link>

    <link name="right_finger">
        <visual>
            <origin xyz="0 0 0.04" rpy="0 0 0" />
            <geometry>
                <box size="0.015 0.015 0.08" />
            </geometry>
            <material name="grey" />
        </visual>

        <collision>
            <origin xyz="0 0 0.04" rpy="0 0 0" />
            <geometry>
                <box size="0.015 0.015 0.08" />
            </geometry>
          <surface>
            <friction>
              <ode>
                <mu>2.0</mu>
                <mu2>2.0</mu2>
              </ode>
            </friction>
          </surface>
        </collision>

        <inertial>
            <origin xyz="0 0 0.04" rpy="0 0 0" />
            <mass value="0.05" />
            <inertia 
                ixx="0.00003" ixy="0.0" ixz="0.0"
                iyy="0.00003" iyz="0.0"
                izz="0.00001" />
        </inertial>
    </link>

    <joint name="gripper_left_finger_joint" type="prismatic">
        <parent link="gripper_base" />
        <child link="left_finger" />
        <origin xyz="0 0.02 0" rpy="0 0 0" />
        <axis xyz="0 1 0" />
        <limit lower="0.0" upper="0.03" effort="5.0" velocity="0.2" />
    </joint>

    <joint name="gripper_right_finger_joint" type="prismatic">
        <parent link="gripper_base" />
        <child link="right_finger" />
        <origin xyz="0 -0.02 0" rpy="0 0 0" />
        <axis xyz="0 -1 0" />
        <limit lower="0.0" upper="0.03" effort="5.0" velocity="0.2" />
    </joint>

    <!-- arm joints -->
    <joint name="base_arm_base_joint" type="revolute">
        <parent link="base_link" />
        <child link="arm_base" />
        <origin xyz="0.1 0 0.2" rpy="0 0 0" />
        <axis xyz="0 0 1" />
        <limit lower="${-pi}" upper="${pi}" effort="10.0" velocity="1.0" />
    </joint>

    <joint name="base_arm_arm1_joint" type="revolute">
        <parent link="arm_base" />
        <child link="arm_1_link" />
        <origin xyz="0 0 0.01" rpy="0 0 0"/>
        <axis xyz="0 1 0" />
        <limit lower="0" upper="${9*pi/20}" effort="10.0" velocity="1.0" />
    </joint>

    <joint name="arm1_arm2_joint" type="revolute">
        <parent link="arm_1_link" />
        <child link="arm_2_link" />
        <origin xyz="0 0 0.2" rpy="0 0 0"/>
        <axis xyz="0 1 0" />
        <limit lower="0" upper="${9*pi/20}" effort="10.0" velocity="1.0" />
    </joint>

    <!-- ros2_control -->
    <ros2_control name="GazeboSystem" type="system">
        <hardware>
            <plugin>gz_ros2_control/GazeboSimSystem</plugin>
        </hardware>

        <joint name="base_arm_base_joint">
            <command_interface name="position" />
            <state_interface name="position" />
            <state_interface name="velocity" />
        </joint>

        <joint name="base_arm_arm1_joint">
            <command_interface name="position" />
            <state_interface name="position" />
            <state_interface name="velocity" />
        </joint>

        <joint name="arm1_arm2_joint">
            <command_interface name="position" />
            <state_interface name="position" />
            <state_interface name="velocity" />
        </joint>

        <joint name="gripper_left_finger_joint">
            <command_interface name="position" />
            <state_interface name="position" />
            <state_interface name="velocity" />
        </joint>

        <joint name="gripper_right_finger_joint">
            <command_interface name="position" />
            <state_interface name="position" />
            <state_interface name="velocity" />
        </joint>
    </ros2_control>

</robot>
<launch>
    <let name="urdf_path" value="$(find-pkg-share my_robot_description)/urdf/my_robot.urdf.xacro" />
    <let name="urdf_config_path" value="$(find-pkg-share my_robot_description)/rviz/urdf_config_nav.rviz" />
    <let name="gazebo_config_path" value="$(find-pkg-share my_robot_bringup)/config/gazebo_bridge.yaml" />
    <let name="world_path" value="$(find-pkg-share my_robot_bringup)/worlds/warehouse_world.sdf" />

    <node pkg="robot_state_publisher" exec="robot_state_publisher" output="screen">
        <param name="robot_description" value="$(command 'xacro $(var urdf_path)')" />
    </node>

    <include file="$(find-pkg-share ros_gz_sim)/launch/gz_sim.launch.py">
        <arg name="gz_args" value="$(var world_path) -r" />
    </include>

    <node pkg="ros_gz_sim" exec="create"
      args="-topic robot_description -x 0.9872775077819824 -y 0.8736683130264282 -z 0.00019168853759765625 -Y 0.0" />

    <node pkg="ros_gz_bridge" exec="parameter_bridge" output="screen">
        <param name="config_file" value="$(var gazebo_config_path)" />
    </node>

    <!-- 读取保存好的地图，并启动 AMCL 定位 -->
    <include file="$(find-pkg-share nav2_bringup)/launch/localization_launch.py">
        <arg name="use_sim_time" value="true" />
        <arg name="map" value="/home/wzs/warehouse_map.yaml" />
        <arg name="params_file" value="/home/wzs/ros2_ws/src/my_robot_bringup/config/nav2_params.yaml" />
    </include>

    <node pkg="rviz2" exec="rviz2" output="screen" args="-d $(var urdf_config_path)" />

    <!-- Load ros2_control controllers -->
    <node
        pkg="controller_manager"
        exec="spawner"
        name="joint_state_broadcaster_spawner"
        output="screen"
        args="joint_state_broadcaster --controller-manager /controller_manager --controller-manager-timeout 30" />

    <node
        pkg="controller_manager"
        exec="spawner"
        name="arm_controller_spawner"
        output="screen"
        args="arm_controller --controller-manager /controller_manager --controller-manager-timeout 30" />
</launch>
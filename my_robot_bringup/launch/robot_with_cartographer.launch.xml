<launch>
    <let name="urdf_path" value="$(find-pkg-share my_robot_description)/urdf/my_robot.urdf.xacro" />
    <let name="urdf_config_path" value="$(find-pkg-share my_robot_description)/rviz/urdf_config_nav.rviz" />
    <let name="gazebo_config_path" value="$(find-pkg-share my_robot_bringup)/config/gazebo_bridge.yaml" />
    <let name="world_path" value="$(find-pkg-share my_robot_bringup)/worlds/warehouse_world.sdf" />

    <node pkg="robot_state_publisher" exec="robot_state_publisher">
        <param name="robot_description" value="$(command 'xacro $(var urdf_path)')" />
    </node>

    <include file="$(find-pkg-share ros_gz_sim)/launch/gz_sim.launch.py">
        <arg name="gz_args" value="$(var world_path) -r" />
    </include>

    <node pkg="ros_gz_sim" exec="create" args="-topic robot_description" />
    <node pkg="rviz2" exec="rviz2" output="screen" args="-d $(var urdf_config_path)" />

    <node pkg="ros_gz_bridge" exec="parameter_bridge">
        <param name="config_file" value="$(var gazebo_config_path)" />
    </node>

    <!-- Cartographer 2D SLAM -->
    <node
        pkg="cartographer_ros"
        exec="cartographer_node"
        name="cartographer_node"
        output="screen"
        args="-configuration_directory $(find-pkg-share my_robot_bringup)/config/cartographer
            -configuration_basename my_robot_2d.lua">

        <param name="use_sim_time" value="true" />

        <!-- Cartographer 默认订阅 scan 和 odom；
            显式重映射能避免话题名不一致 -->
        <remap from="scan" to="/scan" />
        <remap from="odom" to="/odom" />
    </node>

    <!-- 把 Cartographer 子图转换成 /map 栅格地图 -->
    <node
        pkg="cartographer_ros"
        exec="cartographer_occupancy_grid_node"
        name="cartographer_occupancy_grid_node"
        output="screen">

        <param name="use_sim_time" value="true" />
        <param name="resolution" value="0.05" />
        <param name="publish_period_sec" value="1.0" />
    </node>


    <!-- < only using depth camera  for slamtool> -->

    <!-- <node pkg="depthimage_to_laserscan" exec="depthimage_to_laserscan_node" output="screen">
        <remap from="depth" to="/camera/depth/image" />
        <remap from="depth_camera_info" to="/camera/depth/camera_info" />
        <remap from="scan" to="/scan" />

        <param name="output_frame" value="base_link" />
        <param name="scan_height" value="80" />
        <param name="range_min" value="0.1" />
        <param name="range_max" value="4.0" />
    </node> -->

    <!-- <using liadr> -->
    <!-- <node pkg="ros_gz_bridge"
        exec="parameter_bridge"
        name="gz_bridge"
        output="screen"
        args="/clock@rosgraph_msgs/msg/Clock@gz.msgs.Clock
                /model/my_robot/odometry@nav_msgs/msg/Odometry@gz.msgs.Odometry
                /scan@sensor_msgs/msg/LaserScan@gz.msgs.LaserScan" />


   
    -->

    <!-- Load ros2_control controllers -->
    <node
        pkg="controller_manager"
        exec="spawner"
        name="joint_state_broadcaster_spawner"
        args="joint_state_broadcaster --controller-manager /controller_manager --controller-manager-timeout 30" />

    <node
        pkg="controller_manager"
        exec="spawner"
        name="arm_controller_spawner"
        args="arm_controller --controller-manager /controller_manager --controller-manager-timeout 30" />

<!-- make the arm lower to avoid scan -->
    <timer period="10.0">
        <executable
            cmd="ros2 topic pub --times 3 --rate 1 /arm_controller/commands std_msgs/msg/Float64MultiArray &quot;{data: [0.0, 1.414, 1.414, 0.03, 0.03]}&quot;"
            output="screen" />
    </timer>



    
</launch>
